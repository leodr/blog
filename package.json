{
  "name": "simple-blog",
  "version": "1.0.0",
  "description": "",
  "main": "tailwind.config.js",
  "scripts": {
    "generate:dev": "deno run --allow-all --unstable gen.ts --watch",
    "generate": "deno run --allow-all --unstable gen.ts",
    "css:dev": "npx tailwindcss -i ./tailwind.css -o ./out/main.css --watch",
    "css:production": "npx tailwindcss -i ./tailwind.css -o ./out/main.css --minify",
    "dev": "run-p generate:dev css:dev",
    "build": "run-s generate css:production"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.5.1",
    "tailwindcss": "^3.0.1"
  }
}
